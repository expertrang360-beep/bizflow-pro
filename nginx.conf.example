# Example Nginx config for deploying the BizKit SPA.
# Copy the relevant `location` block into your server config.
server {
  listen 80;
  server_name your-domain.com;
  root /var/www/bizkit/dist;
  index index.html;

  # Cache built assets aggressively
  location /assets/ {
    expires 1y;
    add_header Cache-Control "public, immutable";
    try_files $uri =404;
  }

  # SPA fallback: serve index.html for unknown routes so React Router can handle them
  location / {
    try_files $uri $uri/ /index.html;
  }
}
